// ═══════════════════════════════════════════════════════════════
//  firestore.rules — Veggie Saigon Chain
//  Firebase Rules v2  |  Project: veggiesaigonchain
//
//  RBAC Matrix:
//  ┌─────────────────────────┬──────────┬──────────┬──────────┬───────────┐
//  │ Resource                │ Guest    │ Cashier  │ BrAdmin  │ SuperAdmin│
//  ├─────────────────────────┼──────────┼──────────┼──────────┼───────────┤
//  │ GlobalMenu (read)       │   ✓      │   ✓      │   ✓      │    ✓      │
//  │ GlobalMenu (write)      │   ✗      │   ✗      │   ✗      │    ✓      │
//  │ Branches (read info)    │   ✓      │   ✓      │   ✓      │    ✓      │
//  │ Branches (write)        │   ✗      │   ✗      │  own     │    ✓      │
//  │ Branches/Menus (read)   │   ✗      │   ✓      │   ✓      │    ✓      │
//  │ Branches/Menus (write)  │   ✗      │   ✗      │   ✓      │    ✓      │
//  │ Branches/Orders (read)  │  own*    │   ✓      │   ✓      │    ✓      │
//  │ Branches/Orders (create)│   ✓      │   ✓      │   ✓      │    ✓      │
//  │ Branches/Orders (update)│   ✗      │  status  │   ✓      │    ✓      │
//  │ Branches/Staff          │   ✗      │  self    │   ✓      │    ✓      │
//  │ Branches/Vouchers (read)│   ✓      │   ✓      │   ✓      │    ✓      │
//  │ Branches/Vouchers (write)│  ✗      │   ✗      │   ✓      │    ✓      │
//  │ Branches/Invoices       │   ✗      │  create  │   ✓      │    ✓      │
//  └─────────────────────────┴──────────┴──────────┴──────────┴───────────┘
//  * own = khách chỉ đọc được đơn do chính họ tạo (dùng orderId từ session)
// ═══════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────
    //  HELPER FUNCTIONS
    // ────────────────────────────────────────────────────────

    function authed() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return authed()
          && request.auth.token.email == "chaysaigon@gmail.com";
    }

    function isMember(branchId) {
      return authed()
          && exists(/databases/$(database)/documents/Branches/$(branchId)/Staff/$(request.auth.token.email));
    }

    function getRole(branchId) {
      return get(/databases/$(database)/documents/Branches/$(branchId)/Staff/$(request.auth.token.email)).data.role;
    }

    function isAdmin(branchId) {
      return isSuperAdmin()
          || (isMember(branchId) && getRole(branchId) == "admin");
    }

    function isCashier(branchId) {
      return isMember(branchId) && getRole(branchId) == "cashier";
    }

    function isStaff(branchId) {
      return isSuperAdmin() || isMember(branchId);
    }

    // Kiểm tra các trường hợp update hợp lệ khi cashier cập nhật status
    function validStatusOnly() {
      return request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'updatedAt']);
    }

    function validStatus(s) {
      return s in [
        'pending', 'paid', 'preparing',
        'delivering', 'delivered', 'completed', 'cancelled'
      ];
    }

    // Validate order tạo bởi cashier (POS) — chặt chẽ hơn order từ web
    function validPOSOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'items', 'subtotal', 'vat', 'discount', 'total',
        'paymentMethod', 'orderType', 'voucherCode',
        'status', 'cashierEmail', 'createdAt', 'updatedAt'
      ]) && validStatus(d.status);
    }

    // Validate order tạo bởi khách vãng lai (index.html / web order)
    // Cho phép nhiều field hơn vì có thông tin khách hàng, ghi chú...
    function validGuestOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'items', 'subtotal', 'vat', 'discount', 'total',
        'paymentMethod', 'orderType', 'deliveryType', 'voucherCode',
        'customer', 'note', 'status', 'branchId',
        'createdAt', 'updatedAt'
      ])
          && d.status == 'pending'
          && d.orderType == 'weborder';
    }

    // ────────────────────────────────────────────────────────
    //  GLOBAL MENU — Đọc public, chỉ SuperAdmin mới sửa
    // ────────────────────────────────────────────────────────
    match /GlobalMenu/{itemId} {
      allow read:   if true;            // Khách vãng lai đọc được thực đơn
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ────────────────────────────────────────────────────────
    //  BRANCHES
    // ────────────────────────────────────────────────────────
    match /Branches/{branchId} {
      // Cho phép đọc thông tin branch (tên, địa chỉ, SĐT...) để hiển thị
      // trên trang đặt hàng của khách — KHÔNG cần đăng nhập
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isAdmin(branchId);
      allow delete: if isSuperAdmin();

      // ── Menus (thực đơn riêng của từng chi nhánh, nếu dùng) ──
      // Staff đọc được; Admin mới sửa được
      match /Menus/{menuId} {
        allow read:   if isStaff(branchId);
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Orders ───────────────────────────────────────────
      match /Orders/{orderId} {
        // Staff đọc được tất cả đơn.
        // Khách vãng lai chỉ đọc được đơn do chính họ tạo
        // (FE dùng orderId lưu trong sessionStorage để query trực tiếp)
        allow read:   if isStaff(branchId)
                   || !authed();  // Khách không đăng nhập đọc realtime tracking

        // Cashier (POS) tạo đơn — các trường chặt chẽ
        // Guest (Web) tạo đơn weborder — orderType phải là "weborder"
        allow create: if isStaff(branchId)
                   || validGuestOrderCreate();

        // Staff update status; Admin update mọi thứ
        // Khách KHÔNG được update
        allow update: if isAdmin(branchId)
                   || (isCashier(branchId)
                       && validStatusOnly()
                       && validStatus(request.resource.data.status));

        allow delete: if isAdmin(branchId);
      }

      // ── Staff ─────────────────────────────────────────────
      match /Staff/{staffEmail} {
        // Cashier chỉ đọc doc của chính mình (để verify role khi login)
        allow read:   if isAdmin(branchId)
                   || (authed() && request.auth.token.email == staffEmail);
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Vouchers ──────────────────────────────────────────
      // Khách vãng lai cũng cần đọc để validate voucher khi đặt hàng
      match /Vouchers/{voucherId} {
        allow read:   if true;            // Public — khách cần check voucher
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Invoices (lưu metadata hoá đơn đã gửi) ───────────
      match /Invoices/{invoiceId} {
        allow read:   if isStaff(branchId);
        allow create: if isStaff(branchId)
                      && request.resource.data.sentBy == request.auth.token.email;
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── CashLogs (thu chi tiền mặt tại quầy) ─────────────
      match /CashLogs/{logId} {
        allow read:   if isAdmin(branchId)
                   || (isCashier(branchId)
                       && resource.data.cashierEmail == request.auth.token.email);
        allow create: if isStaff(branchId)
                      && request.resource.data.cashierEmail == request.auth.token.email;
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Settings (cấu hình chi nhánh) ────────────────────
      match /Settings/{settingId} {
        allow read:   if isStaff(branchId);
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Chặn mọi sub-collection khác chưa được khai báo ──
      match /{anySubcol}/{anyDoc} {
        allow read, write: if false;
      }
    }

    // ────────────────────────────────────────────────────────
    //  GLOBAL STATS — Aggregated analytics (Super Admin writes)
    // ────────────────────────────────────────────────────────
    match /GlobalStats/{docId} {
      allow read:  if authed();
      allow write: if isSuperAdmin();
    }

    // ────────────────────────────────────────────────────────
    //  DEFAULT DENY — chặn mọi thứ không được khai báo
    // ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
