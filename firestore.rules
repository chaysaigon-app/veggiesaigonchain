// ═══════════════════════════════════════════════════════════════
//  firestore.rules — Veggie Saigon Chain
//  Firebase Rules v2  |  Project: veggiesaigonchain
//
//  Kiến trúc HQ-Branch:
//  GlobalMenu       → Super Admin CRUD. Mọi người đọc được.
//  Branches/{b}/MenuStatus/{itemId} → Branch Admin ghi {available, stock}.
//  Branches/{b}/Orders  → Guest tạo (weborder), Staff đọc/update status.
//  Branches/{b}/Vouchers → Guest đọc để validate, Admin ghi.
// ═══════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────
    //  HELPER FUNCTIONS
    // ────────────────────────────────────────────────────────

    function authed() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return authed()
          && request.auth.token.email == "chaysaigon@gmail.com";
    }

    function isMember(branchId) {
      return authed()
          && exists(/databases/$(database)/documents/Branches/$(branchId)/Staff/$(request.auth.token.email));
    }

    function getRole(branchId) {
      return get(/databases/$(database)/documents/Branches/$(branchId)/Staff/$(request.auth.token.email)).data.role;
    }

    function isAdmin(branchId) {
      return isSuperAdmin()
          || (isMember(branchId) && getRole(branchId) == "admin");
    }

    function isCashier(branchId) {
      return isMember(branchId) && getRole(branchId) == "cashier";
    }

    function isStaff(branchId) {
      return isSuperAdmin() || isMember(branchId);
    }

    // Cashier chỉ được update status + updatedAt
    function validStatusOnly() {
      return request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    function validStatus(s) {
      return s in [
        'pending', 'paid', 'preparing',
        'delivering', 'delivered', 'completed', 'cancelled'
      ];
    }

    // Order tạo từ POS (cashier)
    function validPOSOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'items', 'subtotal', 'vat', 'discount', 'total',
        'paymentMethod', 'orderType', 'voucherCode',
        'status', 'cashierEmail', 'createdAt', 'updatedAt'
      ]) && validStatus(d.status);
    }

    // Order tạo từ web (khách vãng lai)
    function validGuestOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'items', 'subtotal', 'vat', 'discount', 'total',
        'paymentMethod', 'orderType', 'deliveryType', 'voucherCode',
        'customer', 'note', 'status', 'branchId',
        'createdAt', 'updatedAt'
      ])
          && d.status == 'pending'
          && d.orderType == 'weborder';
    }

    // MenuStatus: chỉ cho phép ghi 2 trường
    function validMenuStatus() {
      return request.resource.data.keys().hasOnly(['available', 'stock']);
    }

    // ────────────────────────────────────────────────────────
    //  GLOBAL MENU — HQ Master Catalog
    //  Đọc: tất cả (kể cả khách vãng lai)
    //  Ghi: chỉ Super Admin
    // ────────────────────────────────────────────────────────
    match /GlobalMenu/{itemId} {
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ────────────────────────────────────────────────────────
    //  BRANCHES
    // ────────────────────────────────────────────────────────
    match /Branches/{branchId} {
      // Đọc thông tin branch (tên, địa chỉ) — public để index.html hiển thị
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isAdmin(branchId);
      allow delete: if isSuperAdmin();

      // ── MenuStatus (trạng thái cục bộ của từng chi nhánh) ──
      // Branch Admin + Cashier đọc được (để render menu trên POS)
      // Branch Admin ghi được (Tắt/Mở, sửa stock)
      // Cashier KHÔNG được ghi (chỉ admin mới điều chỉnh tồn kho)
      match /MenuStatus/{itemId} {
        allow read:   if isStaff(branchId) || !authed(); // khách cũng cần đọc
        allow create: if isAdmin(branchId) && validMenuStatus();
        allow update: if isAdmin(branchId) && validMenuStatus();
        allow delete: if isAdmin(branchId);
      }

      // ── Orders ───────────────────────────────────────────
      match /Orders/{orderId} {
        // Staff đọc tất cả; khách vãng lai đọc để tracking realtime
        allow read:   if isStaff(branchId) || !authed();

        // POS cashier hoặc guest weborder tạo đơn
        allow create: if (isStaff(branchId) && validPOSOrderCreate())
                   || validGuestOrderCreate();

        // Admin update mọi thứ; Cashier chỉ update status
        allow update: if isAdmin(branchId)
                   || (isCashier(branchId)
                       && validStatusOnly()
                       && validStatus(request.resource.data.status));

        allow delete: if isAdmin(branchId);
      }

      // ── Staff ─────────────────────────────────────────────
      match /Staff/{staffEmail} {
        allow read:   if isAdmin(branchId)
                   || (authed() && request.auth.token.email == staffEmail);
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Vouchers ─ Public read (khách cần validate khi đặt hàng)
      match /Vouchers/{voucherId} {
        allow read:   if true;
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Invoices (metadata hoá đơn đã gửi) ───────────────
      match /Invoices/{invoiceId} {
        allow read:   if isStaff(branchId);
        allow create: if isStaff(branchId)
                      && request.resource.data.sentBy == request.auth.token.email;
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Settings ─────────────────────────────────────────
      match /Settings/{settingId} {
        allow read:   if isStaff(branchId);
        allow create: if isAdmin(branchId);
        allow update: if isAdmin(branchId);
        allow delete: if isAdmin(branchId);
      }

      // ── Chặn sub-collection khác ──────────────────────────
      match /{any}/{docId} {
        allow read, write: if false;
      }
    }

    // ────────────────────────────────────────────────────────
    //  GLOBAL STATS
    // ────────────────────────────────────────────────────────
    match /GlobalStats/{docId} {
      allow read:  if authed();
      allow write: if isSuperAdmin();
    }

    // ────────────────────────────────────────────────────────
    //  DEFAULT DENY
    // ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
